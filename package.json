{
  "name": "ckn",
  "private": true,
  "version": "0.6.2",
  "type": "module",
  "scripts": {
    "start": "concurrently -n server,vite -c cyan,magenta \"npm run server\" \"npm run dev\"",
    "dev": "vite",
    "server": "tsx server/index.ts",
    "server:watch": "tsx watch server/index.ts",
    "sync": "tsx bin/ckn-sync.ts",
    "sync-shared": "tsx bin/ckn-sync-shared.ts",
    "install-aliases": "tsx bin/ckn-install-aliases.ts",
    "seed-onboarding": "tsx bin/ckn-seed-onboarding.ts",
    "uninstall": "tsx bin/ckn-uninstall.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.check-node.json",
    "check": "node scripts/check-syntax.mjs && tsc --noEmit && tsc -p tsconfig.check-node.json",
    "test:bus": "node scripts/run-bus-tests.mjs",
    "test": "npm run test:bus"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@huggingface/transformers": "^4.2.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/d3": "^7.4.3",
    "@uiw/react-codemirror": "^4.23.7",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^3.6.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "express": "^4.19.2",
    "nanoid": "^5.0.9",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-diff-viewer-continued": "^4.2.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.24.0",
    "sonner": "^1.7.1",
    "tree-sitter-wasms": "^0.1.13",
    "ts-morph": "^28.0.0",
    "web-tree-sitter": "^0.24.7",
    "ws": "^8.18.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
